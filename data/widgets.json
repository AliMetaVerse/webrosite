  {
    "id": "webropol-survey",
    "name": "Webropol survey popup",
    "code": "<!-- Webropol survey popup — responsive, no dependencies -->\n<div class=\"wbpl-overlay\" id=\"wbpl-survey\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Share your feedback\" hidden>\n  <div class=\"wbpl-card\">\n    <div class=\"wbpl-head\">\n      <span class=\"wbpl-title\">Share your feedback</span>\n      <button type=\"button\" class=\"wbpl-close\" aria-label=\"Close survey\">&times;</button>\n    </div>\n    <iframe class=\"wbpl-frame\" title=\"Share your feedback\" src=\"http://localhost:3000/r/6F9903681EF79001\" loading=\"lazy\"></iframe>\n  </div>\n</div>\n\n<style>\n  .wbpl-overlay{position:fixed;inset:0;z-index:2147483000;display:flex;align-items:flex-end;justify-content:center;background:rgba(15,23,42,.55)}\n  .wbpl-overlay[hidden]{display:none}\n  .wbpl-card{display:flex;flex-direction:column;width:100%;max-width:640px;height:min(85vh,720px);border-radius:16px 16px 0 0;animation:wbpl-up .3s ease;background:#fff;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.3)}\n  .wbpl-head{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 16px;border-bottom:1px solid #e5e7eb;font:600 15px/1.2 system-ui,-apple-system,\"Segoe UI\",Roboto,sans-serif;color:#0f172a}\n  .wbpl-close{border:0;background:transparent;font-size:26px;line-height:1;cursor:pointer;color:#64748b}\n  .wbpl-close:hover{color:#0f172a}\n  .wbpl-frame{flex:1 1 auto;width:100%;min-height:0;border:0}\n  @keyframes wbpl-pop{from{opacity:0;transform:scale(.96)}to{opacity:1;transform:none}}\n  @keyframes wbpl-up{from{transform:translateY(100%)}to{transform:none}}\n  @keyframes wbpl-right{from{transform:translateX(100%)}to{transform:none}}\n  @media (max-width:640px){\n    .wbpl-overlay{padding:0}\n    .wbpl-card{max-width:none}\n  }\n</style>\n\n<script>\n(function () {\n  var overlay = document.getElementById('wbpl-survey');\n  if (!overlay) return;\n  function open() { overlay.hidden = false; document.body.style.overflow = 'hidden'; }\n  function close() { overlay.hidden = true; document.body.style.overflow = ''; }\n  window.addEventListener('load', function () { setTimeout(open, 1000); });\n  overlay.querySelector('.wbpl-close').addEventListener('click', close);\n  overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });\n  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !overlay.hidden) close(); });\n})();\n</script>",
    "enabled": true
  }
]